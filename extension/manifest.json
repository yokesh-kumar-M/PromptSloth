{
  "manifest_version": 3,
  "name": "Personal Prompt Engine",
  "version": "1.0",
  "description": "Injects custom AI prompt frameworks and enhances text via local API.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["http://localhost:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}